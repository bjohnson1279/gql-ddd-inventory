generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model InventoryItem {
  id         String @id
  sku        String
  locationId String
  quantity   Int
  allocated  Int    @default(0) @map("allocated")
  inTransit  Int    @default(0) @map("in_transit")
  version    Int

  @@unique([sku, locationId])
  @@map("inventory_items")
}

model Product {
  id        String           @id @db.Uuid
  name      String
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  variants  ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id                  String               @id @db.Uuid
  productId           String               @map("product_id") @db.Uuid
  sku                 String               @unique
  trackingMode        String               @default("quantity") @map("tracking_mode")
  costingMethod       String               @default("fifo") @map("costing_method")
  weightGrams         Int?                 @map("weight_grams")
  volumeCubicMeters   Float?               @map("volume_cubic_meters")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz
  product             Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributes          VariantAttribute[]
  ledgerEntries       LedgerEntry[]
  inventoryCostLayers InventoryCostLayer[]
  serializedItems     SerializedItem[]
  barcodes            Barcode[]

  @@map("product_variants")
}

model VariantAttribute {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId String         @map("variant_id") @db.Uuid
  name      String
  value     String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, name])
  @@map("variant_attributes")
}

model LedgerEntry {
  id          String         @db.Uuid
  tenantId    String         @map("tenant_id")
  locationId  String         @map("location_id")
  variantId   String         @map("variant_id") @db.Uuid
  quantity    Int
  reason      String
  actorId     String         @map("actor_id")
  occurredAt  DateTime       @map("occurred_at") @db.Timestamptz
  referenceId String?        @map("reference_id")
  metadata    Json?          @map("metadata")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@id([id, occurredAt])
  @@map("ledger_entries")
}

model InventoryCostLayer {
  id               String         @id @db.Uuid
  variantId        String         @map("variant_id") @db.Uuid
  initialQuantity  Int            @map("initial_quantity")
  consumedQuantity Int            @default(0) @map("consumed_quantity")
  unitCostCents    Int            @map("unit_cost_cents")
  receivedAt       DateTime       @map("received_at") @db.Timestamptz
  serialNumber     String?        @map("serial_number")
  lotNumber        String?        @map("lot_number")
  expirationDate   DateTime?      @map("expiration_date") @db.Timestamptz
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  variant          ProductVariant @relation(fields: [variantId], references: [id])

  @@index([variantId, receivedAt])
  @@index([variantId, serialNumber])
  @@index([variantId, expirationDate])
  @@index([variantId, lotNumber])
  @@map("inventory_cost_layers")
}

model SerializedItem {
  id           String                  @id @db.Uuid
  variantId    String                  @map("variant_id") @db.Uuid
  serialNumber String                  @map("serial_number")
  tenantId     String                  @map("tenant_id")
  locationId   String                  @map("location_id")
  status       String
  variant      ProductVariant          @relation(fields: [variantId], references: [id])
  history      SerializedItemHistory[]

  @@unique([tenantId, serialNumber])
  @@map("serialized_items")
}

model SerializedItemHistory {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId      String         @map("item_id") @db.Uuid
  fromStatus  String         @map("from_status")
  toStatus    String         @map("to_status")
  reason      String?
  actorId     String         @map("actor_id")
  occurredAt  DateTime       @map("occurred_at") @db.Timestamptz
  referenceId String?        @map("reference_id")
  item        SerializedItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("serialized_item_history")
}

model Barcode {
  id         String         @id @db.Uuid
  variantId  String         @map("variant_id") @db.Uuid
  value      String
  symbology  String
  source     String
  isPrimary  Boolean?       @default(false) @map("is_primary")
  assignedAt DateTime       @map("assigned_at") @db.Timestamptz
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, value])
  @@map("barcodes")
}

model IntegrationConnection {
  id               String            @id @db.Uuid
  tenantId         String            @map("tenant_id")
  platform         String
  storeDomain      String            @map("store_domain")
  accessToken      String            @map("access_token")
  isActive         Boolean?          @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  externalMappings ExternalMapping[]

  @@map("integration_connections")
}

model ExternalMapping {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String                @map("tenant_id")
  integrationId       String                @map("integration_id") @db.Uuid
  entityType          String                @map("entity_type")
  internalId          String                @map("internal_id")
  externalId          String                @map("external_id")
  externalSecondaryId String?               @map("external_secondary_id")
  integration         IntegrationConnection @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, entityType, internalId])
  @@unique([integrationId, entityType, externalId])
  @@map("external_mappings")
}

model ProductUomConfiguration {
  sku                      String           @id
  baseUnitName             String           @map("base_unit_name")
  baseUnitAbbreviation     String           @map("base_unit_abbreviation")
  baseUnitCategory         String           @map("base_unit_category")
  purchaseUnitName         String?          @map("purchase_unit_name")
  purchaseUnitAbbreviation String?          @map("purchase_unit_abbreviation")
  purchaseUnitCategory     String?          @map("purchase_unit_category")
  saleUnitName             String?          @map("sale_unit_name")
  saleUnitAbbreviation     String?          @map("sale_unit_abbreviation")
  saleUnitCategory         String?          @map("sale_unit_category")
  conversionRules          ConversionRule[]

  @@map("product_uom_configurations")
}

model ConversionRule {
  id               String                  @id @db.Uuid
  productUomSku    String                  @map("product_uom_sku")
  unitName         String                  @map("unit_name")
  unitAbbreviation String                  @map("unit_abbreviation")
  unitCategory     String                  @map("unit_category")
  factorToBase     Float                   @map("factor_to_base")
  label            String?
  productUom       ProductUomConfiguration @relation(fields: [productUomSku], references: [sku], onDelete: Cascade)

  @@map("conversion_rules")
}

model JournalEntry {
  id          String        @id @db.Uuid
  tenantId    String        @map("tenant_id")
  date        DateTime      @db.Timestamptz
  description String
  method      String
  referenceId String?       @map("reference_id")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  lines       JournalLine[]

  @@map("journal_entries")
}

model JournalLine {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entryId     String       @map("entry_id") @db.Uuid
  accountCode String       @map("account_code")
  amountCents Int          @map("amount_cents")
  type        String
  memo        String?
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("journal_lines")
}

model StockOnboarding {
  id         String                @id @db.Uuid
  tenantId   String                @map("tenant_id")
  locationId String                @map("location_id")
  status     String
  asOfDate   DateTime              @map("as_of_date") @db.Timestamptz
  createdAt  DateTime              @default(now()) @map("created_at") @db.Timestamptz
  items      StockOnboardingItem[]

  @@map("stock_onboardings")
}

model StockOnboardingItem {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  onboardingId  String          @map("onboarding_id") @db.Uuid
  variantId     String          @map("variant_id") @db.Uuid
  quantity      Int
  unitCostCents Int             @map("unit_cost_cents")
  onboarding    StockOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@unique([onboardingId, variantId])
  @@map("stock_onboarding_items")
}

model Kit {
  id         String         @id @db.Uuid
  sku        String         @unique
  name       String
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz
  components KitComponent[]

  @@map("kits")
}

model KitComponent {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kitId     String @map("kit_id") @db.Uuid
  variantId String @map("variant_id") @db.Uuid
  quantity  Int
  kit       Kit    @relation(fields: [kitId], references: [id], onDelete: Cascade)

  @@unique([kitId, variantId])
  @@map("kit_components")
}

model WebhookEvent {
  id         String   @id
  topic      String
  shopDomain String   @map("shop_domain")
  payload    String   @db.Text
  status     String   @default("Pending")
  attempts   Int      @default(0)
  lastError  String?  @map("last_error") @db.Text
  occurredAt DateTime @map("occurred_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("webhook_events")
}

model OutboxEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType   String    @map("event_type")
  payload     String    @db.Text
  status      String    @default("Pending")
  attempts    Int       @default(0)
  lastError   String?   @map("last_error") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  processedAt DateTime? @map("processed_at") @db.Timestamptz
  nextAttemptAt DateTime  @default(now()) @map("next_attempt_at") @db.Timestamptz

  @@map("outbox_events")
}

model WarehouseLocation {
  id                   String   @id // e.g. "WH1-ZONEA-A03-R02-S01-B10"
  warehouseId          String   @map("warehouse_id")
  zone                 String
  aisle                String
  rack                 String
  shelf                String
  bin                  String
  maxWeightGrams       Int      @map("max_weight_grams")
  maxVolumeCubicMeters Float    @map("max_volume_cubic_meters")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([warehouseId, zone, aisle, rack, shelf, bin])
  @@map("warehouse_locations")
}

model StockTransfer {
  id                    String              @id @db.Uuid
  tenantId              String              @map("tenant_id")
  sourceLocationId      String              @map("source_location_id")
  destinationLocationId String              @map("destination_location_id")
  status                String
  referenceId           String?             @map("reference_id")
  dispatchedAt          DateTime?           @map("dispatched_at") @db.Timestamptz
  receivedAt            DateTime?           @map("received_at") @db.Timestamptz
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz
  items                 StockTransferItem[]

  @@map("stock_transfers")
}

model StockTransferItem {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transferId  String        @map("transfer_id") @db.Uuid
  variantId   String        @map("variant_id") @db.Uuid
  quantity    Int
  transfer    StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@unique([transferId, variantId])
  @@map("stock_transfer_items")
}

model ReplenishmentRule {
  id                    String   @id @db.Uuid
  tenantId              String   @map("tenant_id")
  sku                   String
  locationId            String   @map("location_id")
  reorderPoint          Int      @map("reorder_point")
  reorderQuantity       Int      @map("reorder_quantity")
  safetyStock           Int      @map("safety_stock")
  leadTimeDays          Int      @map("lead_time_days")
  replenishmentType     String   @map("replenishment_type") // "SUPPLIER" | "TRANSFER"
  sourceLocationId      String?  @map("source_location_id")
  supplierId            String?  @map("supplier_id")
  isActive              Boolean  @default(true) @map("is_active")
  dynamicRopEnabled     Boolean  @default(false) @map("dynamic_rop_enabled")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, sku, locationId])
  @@map("replenishment_rules")
}

model PurchaseOrder {
  id                    String              @id @db.Uuid
  tenantId              String              @map("tenant_id")
  supplierId            String              @map("supplier_id")
  destinationLocationId String              @map("destination_location_id")
  status                String              @default("DRAFT")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  items                 PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId String        @map("purchase_order_id") @db.Uuid
  variantId       String        @map("variant_id") @db.Uuid
  quantity        Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@unique([purchaseOrderId, variantId])
  @@map("purchase_order_items")
}

model Tenant {
  id        String   @id
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  users     User[]

  @@map("tenants")
}

model User {
  id           String     @id
  tenantId     String     @map("tenant_id")
  email        String
  passwordHash String     @map("password_hash")
  name         String
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles    UserRole[]
  apiTokens    ApiToken[]

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id              String           @id
  name            String
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId     String @map("role_id")
  permission String
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
  @@map("role_permissions")
}

model ApiToken {
  id         String   @id
  userId     String   @map("user_id")
  tenantId   String   @map("tenant_id")
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_tokens")
}

model Notification {
  id        String   @id @db.Uuid
  tenantId  String   @map("tenant_id")
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("notifications")
}

model DemandForecast {
  id                 String   @id @db.Uuid
  sku                String
  locationId         String   @map("location_id")
  forecastedQuantity Int      @map("forecasted_quantity")
  periodStart        DateTime @map("period_start") @db.Timestamptz
  periodEnd          DateTime @map("period_end") @db.Timestamptz
  confidenceLevel    Float    @map("confidence_level")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([sku, locationId, periodStart, periodEnd])
  @@map("demand_forecasts")
}

model Rma {
  id         String    @id @db.Uuid
  rmaNumber  String    @unique @map("rma_number")
  tenantId   String    @map("tenant_id")
  customerId String    @map("customer_id")
  locationId String    @map("location_id")
  status     String
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  items      RmaItem[]

  @@map("rmas")
}

model RmaItem {
  id               String  @id @db.Uuid
  rmaId            String  @map("rma_id") @db.Uuid
  variantId        String  @map("variant_id") @db.Uuid
  quantity         Int
  receivedQuantity Int     @default(0) @map("received_quantity")
  unitCostCents    Int     @map("unit_cost_cents")
  status           String
  disposition      String?
  rma              Rma     @relation(fields: [rmaId], references: [id], onDelete: Cascade)

  @@map("rma_items")
}

model QuarantineItem {
  id         String    @id @db.Uuid
  variantId  String    @map("variant_id") @db.Uuid
  quantity   Int
  reason     String
  status     String
  locationId String    @map("location_id")
  tenantId   String    @map("tenant_id")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz

  @@map("quarantine_items")
}

model Shipment {
  id                 String   @id @db.Uuid
  sku                String
  quantity           Int
  destinationAddress String   @map("destination_address")
  carrier            String
  trackingNumber     String?  @map("tracking_number")
  labelUrl           String?  @map("label_url")
  shippingRateCents  Int      @map("shipping_rate_cents")
  status             String
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("shipments")
}

model NetsuiteJournalMapping {
  id                 String   @id @db.Uuid
  journalEntryId     String   @unique @map("journal_entry_id") @db.Uuid
  netsuiteJournalId  String   @unique @map("netsuite_journal_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("netsuite_journal_mappings")
}

model XeroJournalMapping {
  id                 String   @id @db.Uuid
  journalEntryId     String   @unique @map("journal_entry_id") @db.Uuid
  xeroJournalId      String   @unique @map("xero_journal_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("xero_journal_mappings")
}

model QuickbooksJournalMapping {
  id                 String   @id @db.Uuid
  journalEntryId     String   @unique @map("journal_entry_id") @db.Uuid
  quickbooksJournalId String  @unique @map("quickbooks_journal_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("quickbooks_journal_mappings")
}


model TenantAccountingConfig {
  tenantId         String @id @map("tenant_id")
  accountingMethod String @default("accrual") @map("accounting_method")
  costingMethod    String @default("fifo") @map("costing_method")

  @@map("tenant_accounting_configs")
}

model AuditDiscrepancy {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  type            String    
  referenceId     String    @map("reference_id") 
  externalRefId   String?   @map("external_ref_id")
  description     String
  status          String    @default("OPEN") 
  occurredAt      DateTime  @default(now()) @map("occurred_at")
  resolvedAt      DateTime? @map("resolved_at")
  resolutionNotes String?   @map("resolution_notes")

  @@map("audit_discrepancies")
}
